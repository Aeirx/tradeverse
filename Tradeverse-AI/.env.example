# Tradeverse AI Environment Variables

# Pinecone key for Vector Database (News Sentiment)
PINECONE_API_KEY=your_pinecone_api_key

# Finnhub API Key for fetching real-time market news
FINNHUB_API_KEY=your_finnhub_api_key

# Shared secret required on every /search and /api/predict request
# (sent by the Express backend in the X-API-Secret header).
# Must match Tradeverse-Backend's AI_SERVICE_SECRET.
API_SECRET=replace_with_long_random_string

# CORS origin — only used as a defence-in-depth fallback; the AI service
# is now expected to be called only by the backend, not the browser.
CORS_ORIGIN=http://localhost:8000
