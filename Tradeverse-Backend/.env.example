# Tradeverse Backend Environment Variables

PORT=8000

# MongoDB URI for database connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net

# Cloudinary keys for avatar uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# JWT Secrets for Authentication
ACCESS_TOKEN_SECRET=your_access_token_secret
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRY=10d

# Redis connection URL for caching live prices
REDIS_URL=redis://localhost:6379

# CORS origin (single browser origin allowed to call this API)
CORS_ORIGIN=http://localhost:5173

# Finnhub API key (live quotes)
FINNHUB_API_KEY=your_finnhub_api_key

# AI service: backend proxies all browser → AI traffic via this URL,
# authenticating itself with AI_SERVICE_SECRET (shared with FastAPI's API_SECRET).
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_SECRET=replace_with_long_random_string

# Node environment — controls cookie `secure` flag among other things
NODE_ENV=development
